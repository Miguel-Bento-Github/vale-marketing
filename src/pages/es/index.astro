---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Hero from '../../components/Hero.astro';
import Features from '../../components/Features.astro';
import ProductShowcase from '../../components/ProductShowcase.astro';
import Pricing from '../../components/Pricing.astro';
import CTA from '../../components/CTA.astro';
import Footer from '../../components/Footer.astro';

const locale = 'es';
---

<Layout
  title="Vale - Gestión Inteligente de Estacionamiento para Restaurantes y Hoteles"
  description="Vale ayuda a restaurantes, hoteles y locales de eventos a asegurar plazas de estacionamiento dedicadas para sus clientes."
>
  <Navigation locale={locale} />
  <main>
    <Hero locale={locale} />
    <Features locale={locale} />
    <ProductShowcase locale={locale} />
    <Pricing locale={locale} />
    <CTA locale={locale} />
  </main>
  <Footer locale={locale} />
</Layout>
