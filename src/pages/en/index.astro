---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Hero from '../../components/Hero.astro';
import Features from '../../components/Features.astro';
import ProductShowcase from '../../components/ProductShowcase.astro';
import Pricing from '../../components/Pricing.astro';
import CTA from '../../components/CTA.astro';
import Footer from '../../components/Footer.astro';

const locale = 'en';
---

<Layout
  title="Vale - Smart Parking Management for Restaurants & Hotels"
  description="Vale helps restaurants, hotels and event venues in Lisbon secure dedicated parking slots for their customers. Save 25 min/day on parking."
  locale={locale}
>
  <Navigation locale={locale} />
  <main>
    <Hero locale={locale} />
    <Features locale={locale} />
    <ProductShowcase locale={locale} />
    <Pricing locale={locale} />
    <CTA locale={locale} />
  </main>
  <Footer locale={locale} />
</Layout>
