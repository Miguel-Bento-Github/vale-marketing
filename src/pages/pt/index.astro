---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Hero from '../../components/Hero.astro';
import Features from '../../components/Features.astro';
import ProductShowcase from '../../components/ProductShowcase.astro';
import Pricing from '../../components/Pricing.astro';
import CTA from '../../components/CTA.astro';
import Footer from '../../components/Footer.astro';

const locale = 'pt';
---

<Layout
  title="Vale - Gestão Inteligente de Estacionamento para Restaurantes e Hotéis"
  description="A Vale ajuda restaurantes, hotéis e espaços de eventos a garantir lugares de estacionamento dedicados para os seus clientes."
>
  <Navigation locale={locale} />
  <main>
    <Hero locale={locale} />
    <Features locale={locale} />
    <ProductShowcase locale={locale} />
    <Pricing locale={locale} />
    <CTA locale={locale} />
  </main>
  <Footer locale={locale} />
</Layout>
