---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Hero from '../../components/Hero.astro';
import Features from '../../components/Features.astro';
import ProductShowcase from '../../components/ProductShowcase.astro';
import Pricing from '../../components/Pricing.astro';
import CTA from '../../components/CTA.astro';
import Footer from '../../components/Footer.astro';

const locale = 'fr';
---

<Layout
  title="Vale - Gestion Intelligente du Stationnement pour Restaurants & Hôtels"
  description="Vale aide les restaurants, hôtels et lieux événementiels à Lisbonne à sécuriser des places de stationnement dédiées. Économisez 25 min/jour sur le stationnement."
  locale={locale}
>
  <Navigation locale={locale} />
  <main>
    <Hero locale={locale} />
    <Features locale={locale} />
    <ProductShowcase locale={locale} />
    <Pricing locale={locale} />
    <CTA locale={locale} />
  </main>
  <Footer locale={locale} />
</Layout>
