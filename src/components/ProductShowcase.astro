---
import { getTranslations } from '../i18n/translations';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

// Map screens to actual screenshot files (light and dark versions, with WebP and PNG)
const screenshots = [
  {
    id: 'calendar',
    lightWebp: '/screenshots/booking-calendar-light.webp',
    lightPng: '/screenshots/booking-calendar-light.png',
    darkWebp: '/screenshots/booking-calendar-dark.webp',
    darkPng: '/screenshots/booking-calendar-dark.png'
  },
  {
    id: 'timeline',
    lightWebp: '/screenshots/timeline-light.webp',
    lightPng: '/screenshots/timeline-light.png',
    darkWebp: '/screenshots/timeline-dark.webp',
    darkPng: '/screenshots/timeline-dark.png'
  },
  {
    id: 'analytics',
    lightWebp: '/screenshots/analytics-dashboard-light.webp',
    lightPng: '/screenshots/analytics-dashboard-light.png',
    darkWebp: '/screenshots/analytics-dashboard-dark.webp',
    darkPng: '/screenshots/analytics-dashboard-dark.png'
  },
  {
    id: 'api',
    lightWebp: '/screenshots/api-docs-light.webp',
    lightPng: '/screenshots/api-docs-light.png',
    darkWebp: '/screenshots/api-docs-dark.webp',
    darkPng: '/screenshots/api-docs-dark.png'
  },
];
---

<section id="product" class="py-24 relative overflow-hidden bg-themed">
  <!-- Background decoration -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-vale-primary/5 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Section header -->
    <div class="text-center mb-16">
      <h2 class="text-headline mb-4 text-themed">{t.product.title}</h2>
      <p class="text-xl text-themed-secondary max-w-2xl mx-auto">{t.product.subtitle}</p>
    </div>

    <!-- Main screenshot showcase -->
    <div class="relative mb-16">
      <div class="screenshot-frame max-w-5xl mx-auto">
        <!-- Screenshot container -->
        <div
          id="main-screenshot"
          class="aspect-video bg-themed-secondary rounded-lg overflow-hidden relative border border-themed"
        >
          <!-- Light mode screenshot -->
          <picture class="light-only">
            <source srcset={screenshots[0].lightWebp} type="image/webp" />
            <img
              id="screenshot-image-light"
              src={screenshots[0].lightPng}
              alt={t.product.screens[0].title}
              class="w-full h-full object-cover object-top transition-opacity duration-300"
              loading="eager"
              width="1280"
              height="800"
            />
          </picture>
          <!-- Dark mode screenshot -->
          <picture class="dark-only absolute inset-0">
            <source srcset={screenshots[0].darkWebp} type="image/webp" />
            <img
              id="screenshot-image-dark"
              src={screenshots[0].darkPng}
              alt={t.product.screens[0].title}
              class="w-full h-full object-cover object-top transition-opacity duration-300"
              loading="eager"
              width="1280"
              height="800"
            />
          </picture>

          <!-- Loading overlay -->
          <div id="screenshot-loading" class="absolute inset-0 bg-themed-secondary flex items-center justify-center opacity-0 transition-opacity duration-300 pointer-events-none">
            <div class="w-8 h-8 border-2 border-vale-primary border-t-transparent rounded-full animate-spin"></div>
          </div>
        </div>
      </div>

      <!-- Floating feature badges -->
      <div class="absolute -left-4 top-1/4 glass px-4 py-2 rounded-lg hidden lg:block animate-float">
        <span class="text-sm font-medium text-themed">Real-time updates</span>
      </div>
      <div class="absolute -right-4 top-1/3 glass px-4 py-2 rounded-lg hidden lg:block animate-float" style="animation-delay: 1s;">
        <span class="text-sm font-medium text-themed">IoT Connected</span>
      </div>
      <div class="absolute -left-4 bottom-1/4 glass px-4 py-2 rounded-lg hidden lg:block animate-float" style="animation-delay: 2s;">
        <span class="text-sm font-medium text-themed">Multi-language</span>
      </div>
    </div>

    <!-- Screenshot selector tabs -->
    <div class="flex flex-wrap justify-center gap-4">
      {t.product.screens.map((screen, index) => (
        <button
          class={`screenshot-tab px-6 py-3 rounded-xl font-medium transition-all ${
            index === 0
              ? 'bg-vale-primary text-white'
              : 'glass text-themed-secondary hover:text-themed hover:bg-white/10'
          }`}
          data-index={index}
          data-title={screen.title}
          data-description={screen.description}
          data-light-webp={screenshots[index]?.lightWebp || ''}
          data-light-png={screenshots[index]?.lightPng || ''}
          data-dark-webp={screenshots[index]?.darkWebp || ''}
          data-dark-png={screenshots[index]?.darkPng || ''}
        >
          {screen.title}
        </button>
      ))}
    </div>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll('.screenshot-tab');
  const screenshotImageLight = document.getElementById('screenshot-image-light') as HTMLImageElement;
  const screenshotImageDark = document.getElementById('screenshot-image-dark') as HTMLImageElement;
  const loadingOverlay = document.getElementById('screenshot-loading');

  // Check WebP support
  const supportsWebP = (() => {
    const canvas = document.createElement('canvas');
    canvas.width = 1;
    canvas.height = 1;
    return canvas.toDataURL('image/webp').startsWith('data:image/webp');
  })();

  // Get the best image source (WebP if supported, otherwise PNG)
  const getImageSrc = (webp: string | null, png: string | null): string => {
    if (supportsWebP && webp) return webp;
    return png || '';
  };

  // Preload all images (both light and dark versions, prefer WebP)
  Array.from(tabs).forEach(tab => {
    const lightWebp = tab.getAttribute('data-light-webp');
    const lightPng = tab.getAttribute('data-light-png');
    const darkWebp = tab.getAttribute('data-dark-webp');
    const darkPng = tab.getAttribute('data-dark-png');

    const lightSrc = getImageSrc(lightWebp, lightPng);
    const darkSrc = getImageSrc(darkWebp, darkPng);

    if (lightSrc) {
      const img = new Image();
      img.src = lightSrc;
    }
    if (darkSrc) {
      const img = new Image();
      img.src = darkSrc;
    }
  });

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      // Update active state
      tabs.forEach((t) => {
        t.classList.remove('bg-vale-primary', 'text-white');
        t.classList.add('glass', 'text-themed-secondary');
      });
      tab.classList.remove('glass', 'text-themed-secondary');
      tab.classList.add('bg-vale-primary', 'text-white');

      // Get image sources (prefer WebP)
      const lightWebp = tab.getAttribute('data-light-webp');
      const lightPng = tab.getAttribute('data-light-png');
      const darkWebp = tab.getAttribute('data-dark-webp');
      const darkPng = tab.getAttribute('data-dark-png');
      const newTitle = tab.getAttribute('data-title');

      const lightSrc = getImageSrc(lightWebp, lightPng);
      const darkSrc = getImageSrc(darkWebp, darkPng);

      // Show loading state
      if (loadingOverlay) {
        loadingOverlay.classList.remove('opacity-0');
        loadingOverlay.classList.add('opacity-100');
      }

      let loadedCount = 0;
      const checkLoaded = () => {
        loadedCount++;
        if (loadedCount >= 2 && loadingOverlay) {
          loadingOverlay.classList.remove('opacity-100');
          loadingOverlay.classList.add('opacity-0');
        }
      };

      if (lightSrc && screenshotImageLight) {
        screenshotImageLight.onload = checkLoaded;
        screenshotImageLight.src = lightSrc;
        screenshotImageLight.alt = newTitle || '';
      }

      if (darkSrc && screenshotImageDark) {
        screenshotImageDark.onload = checkLoaded;
        screenshotImageDark.src = darkSrc;
        screenshotImageDark.alt = newTitle || '';
      }
    });
  });
</script>
