---
import { getTranslations } from '../i18n/translations';
import DemoTimeline from './demos/DemoTimeline.vue';
import DemoCalendar from './demos/DemoCalendar.vue';
import DemoAnalytics from './demos/DemoAnalytics.vue';
import DemoApiDocs from './demos/DemoApiDocs.astro';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const demoIds = ['timeline', 'calendar', 'analytics', 'api'];
---

<section id="product" class="py-24 relative overflow-hidden bg-themed">
  <!-- Background decoration -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-vale-primary/5 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Section header -->
    <div class="text-center mb-16">
      <h2 class="text-headline mb-4 text-themed">{t.product.title}</h2>
      <p class="text-xl text-themed-secondary max-w-2xl mx-auto">{t.product.subtitle}</p>
    </div>

    <!-- Interactive demo showcase -->
    <div class="relative mb-16">
      <div class="demo-frame max-w-5xl mx-auto">
        <!-- Demo container -->
        <div class="demo-container rounded-xl overflow-hidden border border-themed shadow-2xl shadow-vale-primary/10">
          <!-- Timeline Demo (default visible) -->
          <div id="demo-timeline" class="demo-panel active">
            <DemoTimeline client:visible />
          </div>

          <!-- Calendar Demo -->
          <div id="demo-calendar" class="demo-panel">
            <DemoCalendar client:visible />
          </div>

          <!-- Analytics Demo -->
          <div id="demo-analytics" class="demo-panel">
            <DemoAnalytics client:visible />
          </div>

          <!-- API Docs Demo -->
          <div id="demo-api" class="demo-panel">
            <DemoApiDocs />
          </div>
        </div>
      </div>

      <!-- Floating feature badges -->
      <div class="absolute -left-4 top-1/4 glass px-4 py-2 rounded-lg hidden lg:block animate-float">
        <span class="text-sm font-medium text-themed">{t.product.badges.realtime}</span>
      </div>
      <div class="absolute -right-4 top-1/3 glass px-4 py-2 rounded-lg hidden lg:block animate-float" style="animation-delay: 1s;">
        <span class="text-sm font-medium text-themed">{t.product.badges.iot}</span>
      </div>
      <div class="absolute -left-4 bottom-1/4 glass px-4 py-2 rounded-lg hidden lg:block animate-float" style="animation-delay: 2s;">
        <span class="text-sm font-medium text-themed">{t.product.badges.multilang}</span>
      </div>
    </div>

    <!-- Tab selector -->
    <div class="flex flex-wrap justify-center gap-4">
      {t.product.screens.map((screen, index) => (
        <button
          class={`demo-tab px-6 py-3 rounded-xl font-medium transition-all ${
            index === 0
              ? 'bg-vale-primary text-white'
              : 'glass text-themed-secondary hover:text-themed hover:bg-white/10'
          }`}
          data-demo={demoIds[index]}
        >
          {screen.title}
        </button>
      ))}
    </div>
  </div>
</section>

<style>
  .demo-container {
    position: relative;
    height: 520px;
    background: var(--surface, transparent);
  }
  .demo-panel {
    position: absolute;
    inset: 0;
    overflow: auto;
    visibility: hidden;
    opacity: 0;
    transition: opacity 0.2s ease, visibility 0.2s ease;
  }
  .demo-panel.active {
    visibility: visible;
    opacity: 1;
  }
</style>

<script is:inline>
  const demoTabs = document.querySelectorAll('.demo-tab');
  const demoPanels = document.querySelectorAll('.demo-panel');

  demoTabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const targetId = 'demo-' + tab.getAttribute('data-demo');

      // Update tab styles
      demoTabs.forEach((t) => {
        t.classList.remove('bg-vale-primary', 'text-white');
        t.classList.add('glass', 'text-themed-secondary');
      });
      tab.classList.remove('glass', 'text-themed-secondary');
      tab.classList.add('bg-vale-primary', 'text-white');

      // Show/hide panels
      demoPanels.forEach((panel) => {
        if (panel.id === targetId) {
          panel.classList.add('active');
        } else {
          panel.classList.remove('active');
        }
      });
    });
  });
</script>
