---
interface Props {
  locale: string;
}

const { locale } = Astro.props;

const languages = [
  { code: 'en', name: 'English' },
  { code: 'pt', name: 'Português' },
  { code: 'es', name: 'Español' },
  { code: 'zh', name: '中文' },
  { code: 'ar', name: 'العربية' },
  { code: 'de', name: 'Deutsch' },
  { code: 'fr', name: 'Français' },
];

const currentLang = languages.find(l => l.code === locale) || languages[0];

// Get the current page path (e.g., "/en/privacy" -> "/privacy")
const currentPath = Astro.url.pathname;
const pathWithoutLocale = currentPath.replace(new RegExp(`^/${locale}(/|$)`), '/');
// Build locale-aware href that preserves the current page
function langHref(code: string): string {
  return pathWithoutLocale === '/' ? `/${code}` : `/${code}${pathWithoutLocale}`;
}
---

<div class="relative" id="lang-selector">
  <button
    type="button"
    class="flex items-center gap-2 px-3 py-2 rounded-lg text-themed-secondary hover:text-themed hover:bg-themed-tertiary transition-colors text-sm font-medium"
    aria-label="Select language"
    id="lang-toggle"
  >
    <span>{currentLang.name}</span>
    <svg class="w-4 h-4 transition-transform" id="lang-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </button>

  <!-- Dropdown -->
  <div
    id="lang-dropdown"
    class="absolute right-0 mt-2 w-40 rounded-xl bg-themed border border-themed shadow-lg opacity-0 invisible transition-all duration-200 z-50"
  >
    <div class="py-2">
      {languages.map((lang) => (
        <a
          href={langHref(lang.code)}
          data-lang-link
          class={`flex items-center justify-between px-4 py-2 text-sm transition-colors ${
            lang.code === locale
              ? 'text-vale-primary bg-vale-primary/10'
              : 'text-themed-secondary hover:text-themed hover:bg-themed-tertiary'
          }`}
        >
          <span>{lang.name}</span>
          {lang.code === locale && (
            <svg class="w-4 h-4 text-vale-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          )}
        </a>
      ))}
    </div>
  </div>
</div>

<script>
  const toggle = document.getElementById('lang-toggle');
  const dropdown = document.getElementById('lang-dropdown');
  const chevron = document.getElementById('lang-chevron');

  let isOpen = false;

  function openDropdown() {
    isOpen = true;
    dropdown?.classList.remove('opacity-0', 'invisible');
    dropdown?.classList.add('opacity-100', 'visible');
    chevron?.classList.add('rotate-180');
  }

  function closeDropdown() {
    isOpen = false;
    dropdown?.classList.add('opacity-0', 'invisible');
    dropdown?.classList.remove('opacity-100', 'visible');
    chevron?.classList.remove('rotate-180');
  }

  toggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    if (isOpen) {
      closeDropdown();
    } else {
      openDropdown();
    }
  });

  // Close on click outside
  document.addEventListener('click', (e) => {
    const selector = document.getElementById('lang-selector');
    if (selector && !selector.contains(e.target as Node)) {
      closeDropdown();
    }
  });

  // Close on escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeDropdown();
    }
  });

  // Preserve current hash when switching language
  document.querySelectorAll('[data-lang-link]').forEach((link) => {
    link.addEventListener('click', (e) => {
      const hash = location.hash;
      if (hash) {
        e.preventDefault();
        window.location.href = (link as HTMLAnchorElement).href + hash;
      }
    });
  });
</script>
