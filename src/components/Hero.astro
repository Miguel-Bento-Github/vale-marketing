---
import { getTranslations } from '../i18n/translations';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16 bg-themed">
  <!-- Background -->
  <div class="absolute inset-0 vale-gradient opacity-10 dark:opacity-20"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-vale-primary/10 dark:from-vale-primary/20 via-transparent to-transparent"></div>

  <!-- Animated orbs -->
  <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-vale-primary/20 dark:bg-vale-primary/30 rounded-full blur-3xl animate-pulse-slow"></div>
  <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-vale-accent/10 dark:bg-vale-accent/20 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 2s;"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="text-center max-w-4xl mx-auto">
      <!-- Main heading -->
      <h1 class="text-display mb-6 animate-fade-up stagger-1">
        <span class="text-themed">{t.hero.title}</span>
        <br />
        <span class="vale-text-gradient">{t.hero.titleHighlight}</span>
      </h1>

      <!-- Description -->
      <p class="text-xl text-themed-secondary mb-10 max-w-2xl mx-auto leading-relaxed animate-fade-up stagger-2">
        {t.hero.description}
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16 animate-fade-up stagger-3">
        <a
          href={`/${locale}#contact`}
          class="w-full sm:w-auto bg-vale-primary hover:bg-vale-primary/90 text-white px-8 py-4 rounded-xl text-lg font-semibold transition-all hover:shadow-xl hover:shadow-vale-primary/25 hover:-translate-y-0.5"
        >
          {t.hero.cta}
        </a>
        <a
          href={`/${locale}#product`}
          class="w-full sm:w-auto glass text-themed px-8 py-4 rounded-xl text-lg font-semibold transition-all hover:bg-vale-primary/10"
        >
          {t.hero.ctaSecondary}
        </a>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 animate-fade-up stagger-4">
        <div class="text-center">
          <div class="text-4xl font-bold text-vale-primary mb-2">{t.hero.stats.timeSaved}</div>
          <div class="text-themed-secondary">{t.hero.stats.timeSavedLabel}</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-vale-primary mb-2">{t.hero.stats.revenue}</div>
          <div class="text-themed-secondary">{t.hero.stats.revenueLabel}</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-vale-primary mb-2">{t.hero.stats.locations}</div>
          <div class="text-themed-secondary">{t.hero.stats.locationsLabel}</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-themed-tertiary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
