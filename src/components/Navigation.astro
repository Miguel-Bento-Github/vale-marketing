---
import { getTranslations } from '../i18n/translations';
import ThemeToggle from './ThemeToggle.astro';
import LanguageSelector from './LanguageSelector.astro';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<nav class="fixed top-0 inset-x-0 z-50 bg-themed/80 backdrop-blur-lg border-b border-themed">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={`/${locale}`} class="flex items-center gap-2">
        <img src="/logo.svg" alt="Vale" class="h-8 w-auto light-only" />
        <img src="/logo-dark.svg" alt="Vale" class="h-8 w-auto dark-only" />
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        <a href="#features" class="text-themed-secondary hover:text-themed transition-colors text-sm font-medium">
          {t.nav.features}
        </a>
        <a href="#product" class="text-themed-secondary hover:text-themed transition-colors text-sm font-medium">
          {t.nav.product}
        </a>
        <a href="#pricing" class="text-themed-secondary hover:text-themed transition-colors text-sm font-medium">
          {t.nav.pricing}
        </a>
        <a href="#contact" class="text-themed-secondary hover:text-themed transition-colors text-sm font-medium">
          {t.nav.contact}
        </a>
      </div>

      <!-- Right side -->
      <div class="flex items-center gap-2">
        <!-- Theme Toggle -->
        <ThemeToggle />

        <!-- Language Selector -->
        <LanguageSelector locale={locale} />

        <!-- Login -->
        <a
          href="https://demo.valepark.org"
          class="hidden sm:block text-themed-secondary hover:text-themed transition-colors text-sm font-medium px-3 py-2"
        >
          {t.nav.login}
        </a>

        <!-- CTA Button -->
        <a
          href="#contact"
          class="hidden sm:block bg-vale-primary hover:bg-vale-primary/90 text-white px-4 py-2 rounded-lg text-sm font-semibold transition-all hover:shadow-lg hover:shadow-vale-primary/25"
        >
          {t.nav.getStarted}
        </a>

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-button"
          class="md:hidden p-2 text-themed-secondary hover:text-themed rounded-lg hover:bg-themed-tertiary transition-colors"
          aria-label="Toggle menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path id="menu-icon-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            <path id="menu-icon-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-themed border-t border-themed">
    <div class="px-4 py-4 space-y-1">
      <a href="#features" class="block text-themed-secondary hover:text-themed hover:bg-themed-tertiary transition-colors text-sm font-medium py-3 px-3 rounded-lg">
        {t.nav.features}
      </a>
      <a href="#product" class="block text-themed-secondary hover:text-themed hover:bg-themed-tertiary transition-colors text-sm font-medium py-3 px-3 rounded-lg">
        {t.nav.product}
      </a>
      <a href="#pricing" class="block text-themed-secondary hover:text-themed hover:bg-themed-tertiary transition-colors text-sm font-medium py-3 px-3 rounded-lg">
        {t.nav.pricing}
      </a>
      <a href="#contact" class="block text-themed-secondary hover:text-themed hover:bg-themed-tertiary transition-colors text-sm font-medium py-3 px-3 rounded-lg">
        {t.nav.contact}
      </a>
      <a href="https://demo.valepark.org" class="block text-themed-secondary hover:text-themed hover:bg-themed-tertiary transition-colors text-sm font-medium py-3 px-3 rounded-lg">
        {t.nav.login}
      </a>
      <div class="pt-2">
        <a
          href="#contact"
          class="block w-full bg-vale-primary hover:bg-vale-primary/90 text-white px-4 py-3 rounded-lg text-sm font-semibold text-center transition-all"
        >
          {t.nav.getStarted}
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  const menuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIconOpen = document.getElementById('menu-icon-open');
  const menuIconClose = document.getElementById('menu-icon-close');

  let isMenuOpen = false;

  function toggleMenu() {
    isMenuOpen = !isMenuOpen;
    mobileMenu?.classList.toggle('hidden');
    menuIconOpen?.classList.toggle('hidden');
    menuIconClose?.classList.toggle('hidden');
  }

  menuButton?.addEventListener('click', toggleMenu);

  // Close menu when clicking on a link
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      if (isMenuOpen) {
        toggleMenu();
      }
    });
  });
</script>
