---
import { getTranslations } from '../i18n/translations';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<section id="contact" class="py-24 relative overflow-hidden bg-themed">
  <!-- Background -->
  <div class="absolute inset-0 vale-gradient opacity-10 dark:opacity-20"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-vale-primary/10 dark:from-vale-primary/20 via-transparent to-transparent"></div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center">
      <h2 class="text-headline mb-6 text-themed">{t.cta.title}</h2>
      <p class="text-xl text-themed-secondary mb-10 max-w-2xl mx-auto">{t.cta.subtitle}</p>

      <!-- Contact Form -->
      <form id="contact-form" class="max-w-lg mx-auto mb-8 space-y-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <input
            type="text"
            name="name"
            placeholder={locale === 'pt' ? 'Nome' : 'Name'}
            class="w-full px-4 py-3 rounded-xl bg-themed-secondary border border-themed text-themed placeholder-gray-400 dark:placeholder-gray-500 focus:border-vale-primary focus:outline-none focus:ring-1 focus:ring-vale-primary transition-colors"
          />
          <input
            type="text"
            name="company"
            placeholder={locale === 'pt' ? 'Empresa' : 'Company'}
            class="w-full px-4 py-3 rounded-xl bg-themed-secondary border border-themed text-themed placeholder-gray-400 dark:placeholder-gray-500 focus:border-vale-primary focus:outline-none focus:ring-1 focus:ring-vale-primary transition-colors"
          />
        </div>
        <input
          type="email"
          name="email"
          placeholder="Email"
          required
          class="w-full px-4 py-3 rounded-xl bg-themed-secondary border border-themed text-themed placeholder-gray-400 dark:placeholder-gray-500 focus:border-vale-primary focus:outline-none focus:ring-1 focus:ring-vale-primary transition-colors"
        />
        <input
          type="tel"
          name="phone"
          placeholder={locale === 'pt' ? 'Telefone' : 'Phone'}
          class="w-full px-4 py-3 rounded-xl bg-themed-secondary border border-themed text-themed placeholder-gray-400 dark:placeholder-gray-500 focus:border-vale-primary focus:outline-none focus:ring-1 focus:ring-vale-primary transition-colors"
        />
        <textarea
          name="message"
          rows="4"
          placeholder={locale === 'pt' ? 'Mensagem' : 'Message'}
          required
          class="w-full px-4 py-3 rounded-xl bg-themed-secondary border border-themed text-themed placeholder-gray-400 dark:placeholder-gray-500 focus:border-vale-primary focus:outline-none focus:ring-1 focus:ring-vale-primary transition-colors resize-none"
        ></textarea>

        <button
          type="submit"
          id="submit-btn"
          class="w-full bg-vale-primary hover:bg-vale-primary/90 text-white px-8 py-4 rounded-xl text-lg font-semibold transition-all hover:shadow-xl hover:shadow-vale-primary/25 hover:-translate-y-0.5 disabled:opacity-70 disabled:cursor-not-allowed disabled:hover:translate-y-0"
        >
          <span id="btn-text">{t.cta.button}</span>
          <span id="btn-loading" class="hidden items-center justify-center gap-2">
            <svg class="animate-spin h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            {locale === 'pt' ? 'A enviar...' : 'Sending...'}
          </span>
        </button>
      </form>

      <!-- Success/Error messages -->
      <div id="form-success" class="hidden p-4 rounded-xl bg-green-600 text-white font-medium mb-8">
        {locale === 'pt' ? 'Mensagem enviada com sucesso! Entraremos em contacto em breve.' : 'Message sent successfully! We\'ll be in touch soon.'}
      </div>
      <div id="form-error" class="hidden p-4 rounded-xl bg-red-600 text-white font-medium mb-8">
        {locale === 'pt' ? 'Erro ao enviar mensagem. Por favor tente novamente.' : 'Error sending message. Please try again.'}
      </div>

      <!-- Direct contact -->
      <p class="text-themed-tertiary">
        {t.cta.contact}
        <a href="mailto:hello@valepark.org" class="text-vale-primary hover:text-vale-accent transition-colors">
          hello@valepark.org
        </a>
      </p>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text');
  const btnLoading = document.getElementById('btn-loading');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Show loading state
    submitBtn.disabled = true;
    btnText?.classList.add('hidden');
    btnLoading?.classList.remove('hidden');
    btnLoading?.classList.add('flex');

    const formData = new FormData(form);
    const data = Object.fromEntries(formData);

    try {
      const response = await fetch('/.netlify/functions/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (response.ok) {
        successMsg?.classList.remove('hidden');
        errorMsg?.classList.add('hidden');
        form.reset();
      } else {
        throw new Error('Failed to submit');
      }
    } catch {
      errorMsg?.classList.remove('hidden');
      successMsg?.classList.add('hidden');
    } finally {
      // Reset button state
      submitBtn.disabled = false;
      btnText?.classList.remove('hidden');
      btnLoading?.classList.add('hidden');
      btnLoading?.classList.remove('flex');
    }
  });
</script>
