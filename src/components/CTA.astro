---
import { getTranslations } from '../i18n/translations';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<section id="contact" class="py-24 relative overflow-hidden bg-themed">
  <!-- Background -->
  <div class="absolute inset-0 vale-gradient opacity-10 dark:opacity-20"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-vale-primary/10 dark:from-vale-primary/20 via-transparent to-transparent"></div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center">
      <h2 class="text-headline mb-6 text-themed">{t.cta.title}</h2>
      <p class="text-xl text-themed-secondary mb-10 max-w-2xl mx-auto">{t.cta.subtitle}</p>

      <!-- Contact Form -->
      <form id="contact-form" class="max-w-lg mx-auto mb-8 space-y-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <input
            type="text"
            name="name"
            placeholder={locale === 'pt' ? 'Nome' : 'Name'}
            required
            class="w-full px-4 py-3 rounded-xl bg-themed-secondary border border-themed text-themed placeholder-gray-400 dark:placeholder-gray-500 focus:border-vale-primary focus:outline-none focus:ring-1 focus:ring-vale-primary transition-colors"
          />
          <input
            type="text"
            name="company"
            placeholder={locale === 'pt' ? 'Empresa' : 'Company'}
            required
            class="w-full px-4 py-3 rounded-xl bg-themed-secondary border border-themed text-themed placeholder-gray-400 dark:placeholder-gray-500 focus:border-vale-primary focus:outline-none focus:ring-1 focus:ring-vale-primary transition-colors"
          />
        </div>
        <input
          type="email"
          name="email"
          placeholder="Email"
          required
          class="w-full px-4 py-3 rounded-xl bg-themed-secondary border border-themed text-themed placeholder-gray-400 dark:placeholder-gray-500 focus:border-vale-primary focus:outline-none focus:ring-1 focus:ring-vale-primary transition-colors"
        />
        <input
          type="tel"
          name="phone"
          placeholder={locale === 'pt' ? 'Telefone' : 'Phone'}
          class="w-full px-4 py-3 rounded-xl bg-themed-secondary border border-themed text-themed placeholder-gray-400 dark:placeholder-gray-500 focus:border-vale-primary focus:outline-none focus:ring-1 focus:ring-vale-primary transition-colors"
        />
        <textarea
          name="message"
          rows="4"
          placeholder={locale === 'pt' ? 'Mensagem (opcional)' : 'Message (optional)'}
          class="w-full px-4 py-3 rounded-xl bg-themed-secondary border border-themed text-themed placeholder-gray-400 dark:placeholder-gray-500 focus:border-vale-primary focus:outline-none focus:ring-1 focus:ring-vale-primary transition-colors resize-none"
        ></textarea>

        <button
          type="submit"
          class="w-full bg-vale-primary hover:bg-vale-primary/90 text-white px-8 py-4 rounded-xl text-lg font-semibold transition-all hover:shadow-xl hover:shadow-vale-primary/25 hover:-translate-y-0.5"
        >
          {t.cta.button}
        </button>
      </form>

      <!-- Success/Error messages -->
      <div id="form-success" class="hidden p-4 rounded-xl bg-green-500/20 border border-green-500/50 text-green-600 dark:text-green-400 mb-8">
        {locale === 'pt' ? 'Mensagem enviada com sucesso! Entraremos em contacto em breve.' : 'Message sent successfully! We\'ll be in touch soon.'}
      </div>
      <div id="form-error" class="hidden p-4 rounded-xl bg-red-500/20 border border-red-500/50 text-red-600 dark:text-red-400 mb-8">
        {locale === 'pt' ? 'Erro ao enviar mensagem. Por favor tente novamente.' : 'Error sending message. Please try again.'}
      </div>

      <!-- Direct contact -->
      <p class="text-themed-tertiary">
        {t.cta.contact}
        <a href="mailto:hello@valepark.org" class="text-vale-primary hover:text-vale-accent transition-colors">
          hello@valepark.org
        </a>
      </p>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const data = Object.fromEntries(formData);

    try {
      const response = await fetch('/.netlify/functions/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (response.ok) {
        successMsg?.classList.remove('hidden');
        errorMsg?.classList.add('hidden');
        form.reset();
      } else {
        throw new Error('Failed to submit');
      }
    } catch {
      errorMsg?.classList.remove('hidden');
      successMsg?.classList.add('hidden');
    }
  });
</script>
