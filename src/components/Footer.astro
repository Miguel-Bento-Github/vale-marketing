---
import { getTranslations } from '../i18n/translations';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<footer class="py-16 border-t border-themed bg-themed">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <!-- Brand -->
      <div class="md:col-span-2">
        <a href={`/${locale}`} class="inline-block mb-4">
          <img src="/logo.svg" alt="Vale" class="h-10 w-auto light-only" />
          <img src="/logo-dark.svg" alt="Vale" class="h-10 w-auto dark-only" />
        </a>
        <p class="text-themed-secondary max-w-sm">{t.footer.tagline}</p>

        <!-- Social links -->
        <div class="flex gap-4 mt-6">
          <a href="https://www.linkedin.com/company/vale-park" target="_blank" rel="noopener noreferrer" class="text-themed-tertiary hover:text-themed transition-colors" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
            </svg>
          </a>
          <a href="https://x.com/ValeParkOrg" target="_blank" rel="noopener noreferrer" class="text-themed-tertiary hover:text-themed transition-colors" aria-label="X (Twitter)">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Links -->
      <div>
        <h4 class="font-semibold text-themed mb-4">Product</h4>
        <ul class="space-y-3">
          <li>
            <a href={`/${locale}#features`} class="text-themed-secondary hover:text-themed transition-colors">
              {t.footer.links.product}
            </a>
          </li>
          <li>
            <a href={`/${locale}#pricing`} class="text-themed-secondary hover:text-themed transition-colors">
              {t.footer.links.pricing}
            </a>
          </li>
          <li>
            <a href={`/${locale}#contact`} class="text-themed-secondary hover:text-themed transition-colors">
              {t.footer.links.contact}
            </a>
          </li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="font-semibold text-themed mb-4">Legal</h4>
        <ul class="space-y-3">
          <li>
            <a href={`/${locale}/privacy`} class="text-themed-secondary hover:text-themed transition-colors">
              {t.footer.links.privacy}
            </a>
          </li>
          <li>
            <a href={`/${locale}/terms`} class="text-themed-secondary hover:text-themed transition-colors">
              {t.footer.links.terms}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-themed flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-themed-tertiary text-sm">{t.footer.copyright}</p>

      <!-- Payment methods -->
      <div class="flex items-center gap-4">
        <img src="/payments/visa.svg" alt="Visa" class="h-6 w-auto opacity-50" onerror="this.style.display='none'" />
        <img src="/payments/mastercard.svg" alt="Mastercard" class="h-6 w-auto opacity-50" onerror="this.style.display='none'" />
        <img src="/badges/stripe.svg" alt="Stripe" class="h-6 w-auto opacity-50" onerror="this.style.display='none'" />
      </div>
    </div>
  </div>
</footer>
